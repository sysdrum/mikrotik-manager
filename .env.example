# Host ports (maps to the nginx container)
HTTP_PORT=80
HTTPS_PORT=443

# Database
DB_PASSWORD=mikrotik_secure_pw

# JWT Authentication (change to a long random string)
JWT_SECRET=changeme_use_a_long_random_secret_at_least_32_chars

# Device password encryption key (must be exactly 32 characters)
ENCRYPTION_KEY=changeme32byteslongencryptionkey

# InfluxDB
INFLUXDB_TOKEN=mytoken123456789
INFLUXDB_ORG=mikrotik-manager
INFLUXDB_BUCKET=metrics
INFLUXDB_ADMIN_PASSWORD=admin_password_123
